---
import Layout from '../layouts/Layout.astro'
import { client } from '../client.config.js'

let services = []
let testimonials = []
try {
  const [s, t] = await Promise.all([
    fetch(`${client.cmsUrl}/api/services?where[tenant.slug][equals]=${client.tenantSlug}&limit=6`),
    fetch(`${client.cmsUrl}/api/testimonials?where[tenant.slug][equals]=${client.tenantSlug}&limit=3`)
  ])
  services = (await s.json()).docs || []
  testimonials = (await t.json()).docs || []
} catch {}

const displayServices = services.length
  ? services
  : client.services.map((s: string) => ({ title: s, description: `Professional ${s.toLowerCase()} services in ${client.city}.` }))

const primary = client.primaryColor || '#2d5a3d'
---

<Layout title="Home" description={client.tagline}>

  <section style={`padding:5rem 1.5rem;background:linear-gradient(135deg,${primary}18 0%,#fff 65%)`}>
    <div style="max-width:1200px;margin:0 auto">
      <span style={`background:${primary}22;color:${primary};padding:0.3rem 0.9rem;border-radius:20px;font-size:0.85rem;font-weight:500`}>
        Serving {client.city}, {client.state}
      </span>
      <h1 style="font-size:clamp(2rem,5vw,3.5rem);font-weight:800;margin:1rem 0;line-height:1.15;color:#111">
        {client.tagline || `Professional ${client.industry} Services`}
      </h1>
      <p style="font-size:1.1rem;color:#4b5563;max-width:540px;margin-bottom:2rem;line-height:1.7">
        Trusted by homeowners in {client.serviceArea?.slice(0,2).join(' & ')}. Licensed, insured, and ready to help.
      </p>
      <div style="display:flex;gap:1rem;flex-wrap:wrap">
        <a href="/contact" style={`background:${primary};color:#fff;padding:0.85rem 2rem;border-radius:10px;font-weight:700;font-size:1.05rem`}>Get Free Quote</a>
        <a href={`tel:${client.phone}`} style={`border:2px solid ${primary};color:${primary};padding:0.85rem 2rem;border-radius:10px;font-weight:700;font-size:1.05rem`}>{client.phone || 'Call Us'}</a>
      </div>
    </div>
  </section>

  <section style="padding:1.25rem 1.5rem;border-top:1px solid #e5e7eb;border-bottom:1px solid #e5e7eb;background:#f9fafb">
    <div style="max-width:1200px;margin:0 auto;display:flex;flex-wrap:wrap;justify-content:center;gap:2rem;font-size:0.875rem;color:#374151;font-weight:500">
      {['✓ Licensed & Insured', '✓ Free Estimates', '✓ Same Day Service', '✓ 5-Star Rated', '✓ Satisfaction Guaranteed'].map(b => <span>{b}</span>)}
    </div>
  </section>

  <section style="padding:4rem 1.5rem">
    <div style="max-width:1200px;margin:0 auto">
      <div style="text-align:center;margin-bottom:2.5rem">
        <h2 style="font-size:2rem;font-weight:700;margin-bottom:0.75rem">Our Services</h2>
        <p style="color:#6b7280;max-width:500px;margin:0 auto">Comprehensive {client.industry} services for homeowners and businesses in {client.city}.</p>
      </div>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:1.25rem">
        {displayServices.map((service: any) => (
          <div style="padding:1.5rem;border-radius:12px;border:1px solid #e5e7eb">
            <div style={`width:44px;height:44px;border-radius:10px;background:${primary}22;display:flex;align-items:center;justify-content:center;margin-bottom:1rem`}>
              <svg width="22" height="22" fill="none" stroke={primary} viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </div>
            <h3 style="font-weight:700;font-size:1rem;margin-bottom:0.5rem">{service.title}</h3>
            <p style="color:#6b7280;font-size:0.875rem;line-height:1.6">{service.description}</p>
          </div>
        ))}
      </div>
      <div style="text-align:center;margin-top:2rem">
        <a href="/services" style={`border:2px solid ${primary};color:${primary};padding:0.75rem 2rem;border-radius:10px;font-weight:600`}>View All Services →</a>
      </div>
    </div>
  </section>

  <section style={`padding:4rem 1.5rem;background:${primary}12`}>
    <div style="max-width:1200px;margin:0 auto">
      <h2 style="font-size:2rem;font-weight:700;text-align:center;margin-bottom:2.5rem">Why Choose {client.name}?</h2>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:1.25rem">
        {[
          { icon: '🏆', title: 'Years of Experience', desc: 'Trusted by hundreds of local homeowners.' },
          { icon: '⚡', title: 'Fast Response', desc: 'Same-day service. We show up when we say.' },
          { icon: '💯', title: 'Quality Guaranteed', desc: 'Satisfaction guarantee on every job.' },
          { icon: '💰', title: 'Fair Pricing', desc: 'Transparent quotes. No hidden fees.' },
        ].map(item => (
          <div style="text-align:center;padding:1.75rem 1.25rem;background:#fff;border-radius:12px;box-shadow:0 2px 8px rgba(0,0,0,0.05)">
            <div style="font-size:2.5rem;margin-bottom:0.75rem">{item.icon}</div>
            <h3 style="font-weight:700;margin-bottom:0.5rem">{item.title}</h3>
            <p style="color:#6b7280;font-size:0.875rem;line-height:1.6">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {testimonials.length > 0 && (
    <section style="padding:4rem 1.5rem">
      <div style="max-width:1200px;margin:0 auto">
        <h2 style="font-size:2rem;font-weight:700;text-align:center;margin-bottom:2.5rem">What Our Clients Say</h2>
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:1.25rem">
          {testimonials.map((t: any) => (
            <div style="padding:1.5rem;background:#f9fafb;border-radius:12px;border:1px solid #e5e7eb">
              <div style="color:#facc15;margin-bottom:0.75rem">★★★★★</div>
              <p style="color:#374151;font-style:italic;margin-bottom:1rem;line-height:1.7">"{t.text || t.content}"</p>
              <p style="font-weight:700">{t.name || t.author}</p>
              {t.location && <p style="font-size:0.8rem;color:#6b7280">{t.location}</p>}
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <section style={`padding:4rem 1.5rem;background:${primary};color:#fff;text-align:center`}>
    <div style="max-width:700px;margin:0 auto">
      <h2 style="font-size:2rem;font-weight:700;margin-bottom:1rem">Ready to Get Started?</h2>
      <p style="opacity:0.9;margin-bottom:2rem;font-size:1.05rem">Contact us today for a free, no-obligation estimate.</p>
      <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap">
        <a href="/contact" style="background:#fff;color:#111;padding:0.85rem 2.5rem;border-radius:10px;font-weight:700">Get Free Quote</a>
        <a href={`tel:${client.phone}`} style="border:2px solid rgba(255,255,255,0.7);color:#fff;padding:0.85rem 2.5rem;border-radius:10px;font-weight:700">{client.phone || 'Call Us'}</a>
      </div>
    </div>
  </section>

</Layout>