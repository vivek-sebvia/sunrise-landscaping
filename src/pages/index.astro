---
import Layout from "../layouts/Layout.astro";
import { client } from "../client.config.js";

let services = [];
let testimonials = [];
try {
  const [s, t] = await Promise.all([
    fetch(
      `${client.cmsUrl}/api/services?where[tenant.slug][equals]=${client.tenantSlug}&limit=6`,
    ),
    fetch(
      `${client.cmsUrl}/api/testimonials?where[tenant.slug][equals]=${client.tenantSlug}&limit=3`,
    ),
  ]);
  services = (await s.json()).docs || [];
  testimonials = (await t.json()).docs || [];
} catch {}

const serviceImages = {
  "Lawn care": "/images/lawn_care.png",
  "Garden design": "/images/garden_design.png",
  Irrigation: "/images/irrigation.png",
  "Tree trimming": "/images/tree_trimming.png",
  Mulching: "/images/mulching.png",
  "Sod installation": "/images/sod_installation.png",
  "Leaf removal": "/images/leaf_removal.png",
  Hardscaping: "/images/hardscaping.png",
  Planting: "/images/planting.png",
};

const displayServices = services.length
  ? services
  : client.services.map((s: string) => ({
      title: s,
      description: `Professional ${s.toLowerCase()} services in ${client.city}.`,
      image:
        serviceImages[s as keyof typeof serviceImages] ||
        "https://images.unsplash.com/photo-1592419044706-39796d40f98c?auto=format&fit=crop&w=800&q=80",
    }));

const primary = client.primaryColor || "#2d5a3d";
---

<Layout title="Home" description={client.tagline}>
  <style
    set:html={`
    .hero-v3 {
      position: relative;
      background: #fff;
      overflow: hidden;
      min-height: 800px;
      display: flex;
      align-items: center;
      padding-top: 100px;
    }
    .hero-v3::before {
      content: '';
      position: absolute;
      top: 0;
      right: 0;
      width: 50%;
      height: 100%;
      background: var(--primary);
      clip-path: polygon(20% 0, 100% 0, 100% 100%, 0% 100%);
      opacity: 0.05;
      z-index: 0;
    }
    
    .hero-social-v3 {
      position: absolute;
      left: 0;
      top: 0;
      bottom: 0;
      width: 70px;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      gap: 2rem;
      border-right: 1px solid #eee;
      background: #fff;
      z-index: 10;
    }
    .hero-social-v3 a {
      color: #333;
      font-size: 1rem;
      transition: 0.3s;
      writing-mode: vertical-rl;
      text-transform: uppercase;
      letter-spacing: 2px;
      font-weight: 700;
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .hero-social-v3 a i { writing-mode: horizontal-tb; }
    .hero-social-v3 a:hover { color: var(--primary); }
    
    .hero-container {
      display: grid;
      grid-template-columns: 1fr 1fr;
      align-items: center;
      position: relative;
      z-index: 2;
      width: 100%;
      padding-left: 100px; /* Space for social bar */
    }
    
    .hero-content-box {
      background: #fff;
      padding: 3.5rem 4rem;
      border-radius: 0 100px 100px 0;
      box-shadow: 40px 0 60px rgba(0,0,0,0.05);
      position: relative;
      z-index: 3;
      margin-left: -30px;
    }
    
    .hero-subtitle-v3 {
      display: flex;
      align-items: center;
      gap: 15px;
      color: var(--primary);
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 2px;
      font-size: 0.9rem;
      margin-bottom: 1.5rem;
    }
    .hero-subtitle-v3::before {
      content: '';
      width: 40px;
      height: 2px;
      background: var(--primary);
    }
    
    .hero-title-v3 {
      font-size: 4.5rem;
      line-height: 1.1;
      font-weight: 800;
      color: #111;
      margin-bottom: 2rem;
    }
    .hero-title-v3 span {
      color: var(--primary);
    }
    
    .hero-text-v3 {
      font-size: 1.1rem;
      color: #555;
      line-height: 1.8;
      margin-bottom: 2.5rem;
      max-width: 500px;
    }
    
    .hero-btns {
      display: flex;
      align-items: center;
      gap: 2rem;
    }
    .btn-primary-v3 {
      background: var(--primary);
      color: #fff;
      padding: 1.2rem 2.5rem;
      font-weight: 700;
      font-size: 1rem;
      display: flex;
      align-items: center;
      gap: 10px;
      transition: 0.3s;
    }
    .btn-primary-v3:hover {
      background: var(--dark-green);
      transform: translateY(-5px);
    }
    
    .btn-video-v3 {
      display: flex;
      align-items: center;
      gap: 15px;
      font-weight: 800;
      color: #111;
      font-size: 0.9rem;
      text-transform: uppercase;
      letter-spacing: 1px;
    }
    .video-icon {
      width: 55px;
      height: 55px;
      border-radius: 50%;
      background: #fff;
      border: 1px solid #eee;
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--primary);
      font-size: 1rem;
      position: relative;
    }
    .video-icon::after {
      content: '';
      position: absolute;
      top: -5px;
      left: -5px;
      right: -5px;
      bottom: -5px;
      border-radius: 50%;
      border: 1px solid var(--primary);
      opacity: 0.3;
      animation: pulse 2s infinite;
    }
    @keyframes pulse {
      0% { transform: scale(1); opacity: 0.3; }
      100% { transform: scale(1.3); opacity: 0; }
    }
    
    .hero-image-v3 {
      position: relative;
      height: 100%;
      display: flex;
      justify-content: flex-end;
      align-items: flex-end;
    }
    .hero-image-v3 img {
      height: 750px;
      object-fit: contain;
      z-index: 2;
    }
      opacity: 0.1;
    }
    
    .spline-container {
      position: absolute;
      top: 0;
      right: 0;
      width: 100%;
      height: 100%;
      z-index: 1;
      pointer-events: none;
      display: flex;
      align-items: center;
      justify-content: center;
    }


    /* Services V2 */
    .services-v2 { padding: 120px 0; background: #fff; }
    .section-header { text-align: center; margin-bottom: 70px; }
    .section-subtitle { 
      color: var(--primary); 
      font-weight: 800; 
      text-transform: uppercase; 
      letter-spacing: 3px; 
      font-size: 0.9rem; 
      margin-bottom: 1rem; 
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 15px;
    }
    .section-subtitle::before, .section-subtitle::after {
      content: '';
      width: 30px;
      height: 2px;
      background: var(--primary);
    }
    .section-title-v2 { font-size: 3.5rem; font-weight: 800; color: #111; margin-bottom: 1.5rem; }
    
    .services-grid-v2 { display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 2.5rem; }
    @media (max-width: 480px) {
      .services-grid-v2 { grid-template-columns: 1fr; }
    }
    .service-card-v2 { 
      background: #fff; 
      overflow: hidden; 
      box-shadow: 0 10px 40px rgba(0,0,0,0.05); 
      transition: all 0.4s ease;
      position: relative;
      border-bottom: 4px solid transparent;
    }
    .service-card-v2:hover { 
      transform: translateY(-15px); 
      box-shadow: 0 20px 60px rgba(0,0,0,0.1);
      border-bottom-color: var(--primary);
    }
    .service-image-box { position: relative; height: 280px; overflow: hidden; }
    .service-image-box img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.6s ease; }
    .service-card-v2:hover .service-image-box img { transform: scale(1.1); }
    
    .service-icon-box {
      position: absolute;
      bottom: -35px;
      left: 40px;
      width: 70px;
      height: 70px;
      background: #fff;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 2rem;
      color: var(--primary);
      box-shadow: 0 10px 30px rgba(0,0,0,0.1);
      z-index: 2;
    }
    .service-content-v2 { padding: 50px 40px 40px; }
    .service-title-v2 { font-size: 1.6rem; font-weight: 800; margin-bottom: 15px; }
    .service-desc-v2 { color: #666; font-size: 1.05rem; margin-bottom: 25px; line-height: 1.7; }
    .service-link-v2 { font-weight: 800; color: #111; display: flex; align-items: center; gap: 10px; font-size: 0.9rem; text-transform: uppercase; letter-spacing: 1px; }
    .service-link-v2 i { color: var(--primary); transition: 0.3s; }
    .service-link-v2:hover i { transform: translateX(5px); }
    
    /* Info Bar */
    .info-bar-v2 { padding: 30px 0; background: #fff; border-bottom: 1px solid #eee; }
    .info-bar-container { display: flex; flex-wrap: wrap; justify-content: center; gap: 2.5rem; }
    .info-item { display: flex; align-items: center; gap: 8px; font-size: 0.9rem; font-weight: 600; color: #555; }
    .info-item i { color: var(--primary); }

    /* Stats Section */
    .stats-section-v2 { position: relative; padding: 100px 0; background: linear-gradient(135deg, rgba(0,0,0,0.95) 0%, rgba(0,0,0,0.8) 100%), url('/images/hardscaping.png'); background-size: cover; background-position: center; color: #fff; text-align: center; }
    .stats-overlay { position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.3); pointer-events: none; }
    .stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 3rem; position: relative; z-index: 2; }
    .stat-number { font-size: 4.5rem; font-weight: 900; color: var(--primary); margin-bottom: 5px; line-height: 1; text-shadow: 0 10px 30px rgba(0,0,0,0.3); }
    .stat-line { width: 40px; height: 3px; background: var(--primary); margin: 15px auto; opacity: 0.6; }
    .stat-label { font-size: 0.85rem; font-weight: 800; text-transform: uppercase; letter-spacing: 2px; color: rgba(255,255,255,0.8); }

    /* Benefits Section */
    .benefits-v2 { padding: 100px 0; background: #fff; }
    .benefits-grid-v2 { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 2rem; }
    .benefit-card-v2 { padding: 40px 30px; background: #f9f9f9; border-radius: 12px; text-align: center; transition: all 0.3s ease; }
    .benefit-card-v2:hover { transform: translateY(-10px); box-shadow: 0 15px 40px rgba(0,0,0,0.05); background: #fff; }
    .benefit-icon-v2 { font-size: 2.5rem; color: var(--primary); margin-bottom: 20px; }
    .benefit-title-v2 { font-size: 1.4rem; font-weight: 700; margin-bottom: 15px; color: #111; }
    .benefit-desc-v2 { color: #666; line-height: 1.7; font-size: 1rem; }

    /* CTA Section */
    .cta-section-v2 { padding: 80px 0; background: var(--primary); color: #fff; position: relative; overflow: hidden; }
    .cta-pattern { position: absolute; top: 0; left: 0; width: 100%; height: 100%; opacity: 0.1; background-image: url('https://www.transparenttextures.com/patterns/leaf.png'); }
    .cta-container { position: relative; z-index: 2; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 3rem; }
    .cta-content { max-width: 700px; }
    .cta-title { font-size: 3rem; color: #fff; margin-bottom: 1.5rem; font-weight: 800; }
    .cta-text { font-size: 1.2rem; opacity: 0.9; line-height: 1.7; }
    .cta-actions { display: flex; gap: 1.5rem; flex-wrap: wrap; }
    .btn-cta-white { background: #fff; color: var(--secondary); padding: 1.2rem 2.5rem; border-radius: 4px; font-weight: 700; font-size: 1rem; box-shadow: 0 10px 20px rgba(0,0,0,0.1); transition: 0.3s; }
    .btn-cta-outline { border: 2px solid #fff; color: #fff; padding: 1.2rem 2.5rem; border-radius: 4px; font-weight: 700; font-size: 1rem; transition: 0.3s; }
    .btn-cta-white:hover { transform: translateY(-3px); box-shadow: 0 15px 30px rgba(0,0,0,0.15); }
    .btn-cta-outline:hover { background: #fff; color: var(--primary); }

    /* Testimonials */
    .testimonials-v2 { padding: 100px 0; background: #f9f9f9; }
    .testimonial-grid-v2 { display: grid; grid-template-columns: repeat(auto-fit, minmax(350px, 1fr)); gap: 2.5rem; }
    .testimonial-card-v2 { background: #fff; padding: 40px; border-radius: 15px; position: relative; box-shadow: 0 10px 30px rgba(0,0,0,0.05); transition: 0.3s; }
    .testimonial-card-v2:hover { transform: translateY(-10px); box-shadow: 0 20px 50px rgba(0,0,0,0.1); }
    .testimonial-quote-icon { position: absolute; top: 40px; right: 40px; font-size: 2rem; color: var(--primary); opacity: 0.1; }
    .testimonial-stars { color: #facc15; margin-bottom: 20px; font-size: 0.9rem; }
    .testimonial-text { color: #444; font-style: italic; margin-bottom: 25px; line-height: 1.8; font-size: 1.05rem; }
    .testimonial-author { display: flex; align-items: center; gap: 15px; }
    .author-avatar { width: 50px; height: 50px; border-radius: 50%; background: var(--primary); color: #fff; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 1.2rem; }
    .author-name { font-weight: 700; color: #111; font-size: 1.1rem; margin: 0; }
    .author-meta { font-size: 0.85rem; color: #777; margin: 0; }

    @media (max-width: 1200px) {
      .hero-title-v3 { font-size: 3.2rem; }
      .hero-container { grid-template-columns: 1fr 1fr; padding-left: 50px; }
      .hero-image-v3 img { height: 500px; }
      .hero-v3 { min-height: 700px; }
    }
    @media (max-width: 992px) {
      .hero-v3 { padding-top: 120px; min-height: auto; align-items: center; padding-bottom: 60px; }
      .hero-container { grid-template-columns: 1fr; text-align: center; padding-left: 0; }
      .hero-content-box { margin: 0 auto; border-radius: 40px; box-shadow: 0 20px 40px rgba(0,0,0,0.05); padding: 3rem 2rem; max-width: 600px; }
      .hero-subtitle-v3 { justify-content: center; }
      .hero-text-v3 { margin: 0 auto 2.5rem; }
      .hero-btns { justify-content: center; }
      .hero-image-v3 { display: none; }
      .section-title-v2 { font-size: 2.8rem; }
      .stat-number { font-size: 3.5rem; }
      .stats-grid { gap: 2rem; }
    }
    @media (max-width: 768px) {
      .hero-v3 { padding-top: 100px; }
      .hero-social-v3 { display: none; }
      .hero-container { padding-left: 0; padding: 0 1rem; }
      .hero-title-v3 { font-size: 2.2rem; }
      .hero-content-box { padding: 2rem 1rem; border-radius: 20px; }
      .hero-text-v3 { font-size: 1rem; }
      .btn-primary-v3 { padding: 1rem 1.5rem; font-size: 0.9rem; }
      .hero-btns { flex-direction: column; gap: 1rem; align-items: center; }
      .section-title-v2 { font-size: 2.2rem; }
      .info-bar-container { gap: 1.5rem; }
      .stats-section-v2 { padding: 70px 0; }
      .stat-number { font-size: 3rem; }
      .cta-title { font-size: 2.2rem; }
      .cta-container { text-align: center; justify-content: center; }
      .cta-actions { justify-content: center; width: 100%; }
      .btn-cta-white, .btn-cta-outline { width: 100%; text-align: center; }
      .testimonial-grid-v2 { grid-template-columns: 1fr; }
    }
  `}
  ></style>

  <section class="hero-v3">
    <div class="hero-social-v3">
      <a href="#">Fb</a>
      <a href="#">Tw</a>
      <a href="#">Pn</a>
      <a href="#">In</a>
    </div>

    <div class="hero-container">
      <div class="hero-content-box">
        <span class="hero-subtitle-v3">Professional Gardening</span>
        <h1 class="hero-title-v3">
          Trusted <span>Landscaping</span> & Lawn Care
        </h1>
        <p class="hero-text-v3">
          We are professional landscaping services provider in {client.city}.
          Our team of experts is dedicated to transforming your outdoor spaces
          into beautiful, functional landscapes.
        </p>
        <div class="hero-btns">
          <a href="/contact" class="btn-primary-v3"
            >Explore Services <i class="fas fa-arrow-right"></i></a
          >
          <a href="#" class="btn-video-v3">
            <div class="video-icon">
              <i class="fas fa-play"></i>
            </div>
            Watch Video
          </a>
        </div>
      </div>

      <div class="hero-image-v3">
        <div class="image-bg-shape"></div>
        <div class="spline-container">
          <spline-viewer
            url="https://prod.spline.design/6Wq1Q7YGyH-S-N63/scene.splinecode"
          ></spline-viewer>
        </div>
        <img src="/images/hero_gardener.png" alt="Gardener" />
      </div>
    </div>
  </section>

  <section class="info-bar-v2">
    <div class="container info-bar-container">
      {
        [
          "Licensed & Insured",
          "Free Estimates",
          "Same Day Service",
          "5-Star Rated",
          "Satisfaction Guaranteed",
        ].map((b) => (
          <span class="info-item">
            <i class="fas fa-check-circle" /> {b}
          </span>
        ))
      }
    </div>
  </section>

  <section class="services-v2">
    <div class="container">
      <div class="section-header">
        <span class="section-subtitle">What We Offer</span>
        <h2 class="section-title-v2">Our Professional Services</h2>
        <p
          style="max-width: 600px; margin: 0 auto; color: #666; font-size: 1.1rem; line-height: 1.8;"
        >
          Comprehensive {client.industry} services for homeowners and businesses in
          {client.city}.
        </p>
      </div>

      <div class="services-grid-v2">
        {
          displayServices.map((service: any) => (
            <div class="service-card-v2">
              <div class="service-image-box">
                <img src={service.image} alt={service.title} />
                <div class="service-icon-box">
                  <i class="fas fa-leaf" />
                </div>
              </div>
              <div class="service-content-v2">
                <h3 class="service-title-v2">{service.title}</h3>
                <p class="service-desc-v2">{service.description}</p>
                <a href="/services" class="service-link-v2">
                  Read More <i class="fas fa-arrow-right" />
                </a>
              </div>
            </div>
          ))
        }
      </div>

      <div style="text-align:center; margin-top:70px;">
        <a
          href="/services"
          class="btn-primary-v3"
          style="display:inline-flex; border: 1px solid var(--primary); background: transparent; color: var(--primary);"
          >View All Services</a
        >
      </div>
    </div>
  </section>

  <section class="stats-section-v2">
    <div class="stats-overlay"></div>
    <div class="container stats-container">
      <div class="stats-grid">
        <div class="stat-item">
          <h2 class="stat-number">15+</h2>
          <div class="stat-line"></div>
          <p class="stat-label">Years Experience</p>
        </div>
        <div class="stat-item">
          <h2 class="stat-number">500+</h2>
          <div class="stat-line"></div>
          <p class="stat-label">Projects Done</p>
        </div>
        <div class="stat-item">
          <h2 class="stat-number">100%</h2>
          <div class="stat-line"></div>
          <p class="stat-label">Satisfaction</p>
        </div>
        <div class="stat-item">
          <h2 class="stat-number">12+</h2>
          <div class="stat-line"></div>
          <p class="stat-label">Expert Workers</p>
        </div>
      </div>
    </div>
  </section>

  <section class="benefits-v2">
    <div class="container">
      <div class="section-header">
        <span class="section-subtitle">Benefits</span>
        <h2 class="section-title-v2">Why Choose {client.name}?</h2>
      </div>
      <div class="benefits-grid-v2">
        {
          [
            {
              icon: "fas fa-award",
              title: "Years of Experience",
              desc: "Trusted by hundreds of local homeowners.",
            },
            {
              icon: "fas fa-bolt",
              title: "Fast Response",
              desc: "Same-day service. We show up when we say.",
            },
            {
              icon: "fas fa-thumbs-up",
              title: "Quality Guaranteed",
              desc: "Satisfaction guarantee on every job.",
            },
            {
              icon: "fas fa-tag",
              title: "Fair Pricing",
              desc: "Transparent quotes. No hidden fees.",
            },
          ].map((item) => (
            <div class="benefit-card-v2">
              <div class="benefit-icon-v2">
                <i class={item.icon} />
              </div>
              <h3 class="benefit-title-v2">{item.title}</h3>
              <p class="benefit-desc-v2">
                {item.desc}
              </p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  {
    testimonials.length > 0 && (
      <section class="testimonials-v2">
        <div class="container">
          <div class="section-header">
            <span class="section-subtitle">Testimonials</span>
            <h2 class="section-title-v2">What Our Clients Say</h2>
          </div>
          <div class="testimonial-grid-v2">
            {testimonials.map((t: any) => (
              <div class="testimonial-card-v2">
                <i class="fas fa-quote-right testimonial-quote-icon" />
                <div class="testimonial-stars">
                  <i class="fas fa-star" />
                  <i class="fas fa-star" />
                  <i class="fas fa-star" />
                  <i class="fas fa-star" />
                  <i class="fas fa-star" />
                </div>
                <p class="testimonial-text">
                  "{t.text || t.content}"
                </p>
                <div class="testimonial-author">
                  <div class="author-avatar">
                    {(t.name || t.author || "C").charAt(0)}
                  </div>
                  <div>
                    <h4 class="author-name">{t.name || t.author}</h4>
                    <p class="author-meta">Verified Customer</p>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>
    )
  }

  <section class="cta-section-v2">
    <div class="cta-pattern"></div>
    <div class="container cta-container">
      <div class="cta-content">
        <h2 class="cta-title">Ready to Get Started?</h2>
        <p class="cta-text">
          Contact us today for a free, no-obligation estimate and let us
          transform your outdoor space into something extraordinary.
        </p>
      </div>
      <div class="cta-actions">
        <a href="/contact" class="btn-cta-white">Get Free Quote</a>
        <a href={`tel:${client.phone}`} class="btn-cta-outline">Call: {client.phone || "Us"}</a>
      </div>
    </div>
  </section>

  <script is:inline>
    // @ts-nocheck
    window.addEventListener("load", () => {
      if (typeof Motion === "undefined") return;
      const { animate, inView, stagger } = Motion;

      // Hero Animations
      animate(
        ".hero-title-v3",
        { opacity: [0, 1], y: [50, 0] },
        { duration: 1, easing: "ease-out" },
      );
      animate(
        ".hero-text-v3",
        { opacity: [0, 1], y: [30, 0] },
        { duration: 1, delay: 0.2 },
      );
      animate(
        ".hero-btns",
        { opacity: [0, 1], y: [20, 0] },
        { duration: 0.8, delay: 0.4 },
      );
      animate(
        ".hero-social-v3",
        { x: [-50, 0], opacity: [0, 1] },
        { duration: 1 },
      );

      // Scroll Animations
      inView(".service-card-v2", ({ target }) => {
        animate(
          target,
          { opacity: [0, 1], y: [50, 0] },
          { duration: 0.6 }
        );
      });

      inView(".stat-item", ({ target }) => {
        animate(
          target,
          { opacity: [0, 1], y: [30, 0] },
          { duration: 0.6 }
        );
      });

      inView(".section-title-v2", ({ target }) => {
        animate(
          target,
          { opacity: [0, 1], scale: [0.9, 1] },
          { duration: 0.8 },
        );
      });

      inView(".faq-item", ({ target }) => {
        animate(target, { opacity: [0, 1], x: [-30, 0] }, { duration: 0.6 });
      });
    });
  </script>
</Layout>
