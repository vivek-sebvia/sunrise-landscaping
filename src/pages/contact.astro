---
import Layout from '../layouts/Layout.astro'
import { client } from '../client.config.js'
const primary = client.primaryColor || '#2d5a3d'
---

<Layout title="Contact Us" description={`Contact ${client.name} for a free estimate. Serving ${client.city}, ${client.state}.`}>

  <section style={`padding:4rem 1.5rem;background:${primary}12;text-align:center`}>
    <div style="max-width:1200px;margin:0 auto">
      <h1 style="font-size:2.5rem;font-weight:800;margin-bottom:1rem">Contact Us</h1>
      <p style="color:#6b7280;font-size:1.05rem">Get your free estimate today. We respond within 24 hours.</p>
    </div>
  </section>

  <section style="padding:4rem 1.5rem">
    <div style="max-width:1200px;margin:0 auto;display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:3rem">

      <div style="background:#fff;border-radius:16px;border:1px solid #e5e7eb;padding:2rem;box-shadow:0 2px 12px rgba(0,0,0,0.05)">
        <h2 style="font-size:1.5rem;font-weight:700;margin-bottom:1.5rem">Get a Free Quote</h2>
        <form id="contact-form" style="display:flex;flex-direction:column;gap:1rem">
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem">
            <div>
              <label style="display:block;font-size:0.8rem;font-weight:600;color:#374151;margin-bottom:0.4rem;text-transform:uppercase;letter-spacing:0.05em">First Name *</label>
              <input type="text" name="firstName" required style="width:100%;padding:0.75rem;border:1px solid #d1d5db;border-radius:8px;font-size:0.9rem;box-sizing:border-box" />
            </div>
            <div>
              <label style="display:block;font-size:0.8rem;font-weight:600;color:#374151;margin-bottom:0.4rem;text-transform:uppercase;letter-spacing:0.05em">Last Name *</label>
              <input type="text" name="lastName" required style="width:100%;padding:0.75rem;border:1px solid #d1d5db;border-radius:8px;font-size:0.9rem;box-sizing:border-box" />
            </div>
          </div>
          <div>
            <label style="display:block;font-size:0.8rem;font-weight:600;color:#374151;margin-bottom:0.4rem;text-transform:uppercase;letter-spacing:0.05em">Phone *</label>
            <input type="tel" name="phone" required style="width:100%;padding:0.75rem;border:1px solid #d1d5db;border-radius:8px;font-size:0.9rem;box-sizing:border-box" />
          </div>
          <div>
            <label style="display:block;font-size:0.8rem;font-weight:600;color:#374151;margin-bottom:0.4rem;text-transform:uppercase;letter-spacing:0.05em">Email</label>
            <input type="email" name="email" style="width:100%;padding:0.75rem;border:1px solid #d1d5db;border-radius:8px;font-size:0.9rem;box-sizing:border-box" />
          </div>
          <div>
            <label style="display:block;font-size:0.8rem;font-weight:600;color:#374151;margin-bottom:0.4rem;text-transform:uppercase;letter-spacing:0.05em">Service Needed *</label>
            <select name="service" required style="width:100%;padding:0.75rem;border:1px solid #d1d5db;border-radius:8px;font-size:0.9rem;background:#fff;box-sizing:border-box">
              <option value="">Select a service...</option>
              {client.services.map((s: string) => <option value={s}>{s}</option>)}
              <option value="other">Other</option>
            </select>
          </div>
          <div>
            <label style="display:block;font-size:0.8rem;font-weight:600;color:#374151;margin-bottom:0.4rem;text-transform:uppercase;letter-spacing:0.05em">Message</label>
            <textarea name="message" rows="4" placeholder="Describe your project..." style="width:100%;padding:0.75rem;border:1px solid #d1d5db;border-radius:8px;font-size:0.9rem;resize:vertical;box-sizing:border-box"></textarea>
          </div>
          <button type="submit" style={`background:${primary};color:#fff;padding:0.9rem;border-radius:10px;font-size:1rem;font-weight:700;border:none;cursor:pointer`}>
            Send Message
          </button>
        </form>
        <div id="form-success" style="display:none;margin-top:1rem;padding:1rem;background:#dcfce7;border-radius:8px;color:#166534;font-weight:500;text-align:center">
          ✓ Thank you! We'll be in touch within 24 hours.
        </div>
      </div>

      <div style="display:flex;flex-direction:column;gap:1.25rem">
        <h2 style="font-size:1.5rem;font-weight:700">Get in Touch</h2>
        {client.phone && (
          <a href={`tel:${client.phone}`} style="display:flex;align-items:center;gap:1rem;padding:1.25rem;border-radius:12px;border:1px solid #e5e7eb;text-decoration:none;color:#111">
            <div style={`width:48px;height:48px;border-radius:12px;background:${primary}22;display:flex;align-items:center;justify-content:center;flex-shrink:0`}>
              <svg width="22" height="22" fill="none" stroke={primary} viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            </div>
            <div>
              <p style="font-size:0.8rem;color:#6b7280;margin-bottom:0.2rem">Phone</p>
              <p style="font-weight:600">{client.phone}</p>
            </div>
          </a>
        )}
        {client.email && (
          <a href={`mailto:${client.email}`} style="display:flex;align-items:center;gap:1rem;padding:1.25rem;border-radius:12px;border:1px solid #e5e7eb;text-decoration:none;color:#111">
            <div style={`width:48px;height:48px;border-radius:12px;background:${primary}22;display:flex;align-items:center;justify-content:center;flex-shrink:0`}>
              <svg width="22" height="22" fill="none" stroke={primary} viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            </div>
            <div>
              <p style="font-size:0.8rem;color:#6b7280;margin-bottom:0.2rem">Email</p>
              <p style="font-weight:600">{client.email}</p>
            </div>
          </a>
        )}
        {client.address && (
          <div style="display:flex;align-items:center;gap:1rem;padding:1.25rem;border-radius:12px;border:1px solid #e5e7eb">
            <div style={`width:48px;height:48px;border-radius:12px;background:${primary}22;display:flex;align-items:center;justify-content:center;flex-shrink:0`}>
              <svg width="22" height="22" fill="none" stroke={primary} viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            </div>
            <div>
              <p style="font-size:0.8rem;color:#6b7280;margin-bottom:0.2rem">Address</p>
              <p style="font-weight:600">{client.address}, {client.city}, {client.state}</p>
            </div>
          </div>
        )}
        <div style={`padding:1.5rem;border-radius:12px;background:${primary}12`}>
          <h3 style="font-weight:700;margin-bottom:0.75rem">Service Areas</h3>
          <div style="display:flex;flex-wrap:wrap;gap:0.5rem">
            {client.serviceArea?.map((area: string) => (
              <span style={`background:#fff;color:${primary};padding:0.3rem 0.75rem;border-radius:20px;font-size:0.8rem;font-weight:500`}>{area}</span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

</Layout>

<script>
  document.getElementById('contact-form')?.addEventListener('submit', (e) => {
    e.preventDefault()
    const form = document.getElementById('contact-form') as HTMLElement
    const success = document.getElementById('form-success') as HTMLElement
    form.style.display = 'none'
    success.style.display = 'block'
  })
</script>