---
import Layout from "../layouts/Layout.astro";
import { client } from "../client.config.js";
const primary = client.primaryColor || "#2d5a3d";
---

<Layout
  title="Contact Our Expert Team"
  description={`Get a free estimate for your landscaping project in ${client.city}. Our expert team is ready to transform your outdoor space.`}
>
  <!-- Premium Hero -->
  <section class="contact-hero">
    <div class="container">
      <div class="hero-content">
        <span class="subtitle">GET IN TOUCH</span>
        <h1>
          Let's Build Your <span class="text-accent">Dream</span> Landscape
        </h1>
        <p>
          From custom garden designs to professional lawn maintenance, our team
          is here to bring your vision to life.
        </p>
      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <section class="contact-main">
    <div class="container">
      <div class="contact-grid">
        <!-- Contact Form -->
        <div class="form-wrapper">
          <div class="form-header">
            <h2>Send Us a Message</h2>
            <p>
              Fill out the form below and we'll get back to you within 24 hours.
            </p>
          </div>

          <form id="contact-form" class="premium-form">
            <div class="input-group-row">
              <div class="field">
                <label>First Name *</label>
                <input
                  type="text"
                  name="firstName"
                  placeholder="John"
                  required
                />
              </div>
              <div class="field">
                <label>Last Name *</label>
                <input type="text" name="lastName" placeholder="Doe" required />
              </div>
            </div>

            <div class="input-group-row">
              <div class="field">
                <label>Phone Number *</label>
                <input
                  type="tel"
                  name="phone"
                  placeholder="(555) 000-0000"
                  required
                />
              </div>
              <div class="field">
                <label>Email Address</label>
                <input
                  type="email"
                  name="email"
                  placeholder="john@example.com"
                />
              </div>
            </div>

            <div class="field">
              <label>Service Interested In *</label>
              <div class="custom-select" id="service-select">
                <div class="select-trigger">
                  <span class="trigger-text">Select a service...</span>
                  <i class="fas fa-chevron-down"></i>
                </div>
                <div class="options-list">
                  <div class="option" data-value="">Select a service...</div>
                  {client.services.map((s: string) => <div class="option" data-value={s}>{s}</div>)}
                  <div class="option" data-value="other">Other / Custom Project</div>
                </div>
                <input type="hidden" name="service" id="service-hidden" required />
              </div>
            </div>

            <div class="field">
              <label>Your Message</label>
              <textarea
                name="message"
                rows="5"
                placeholder="Tell us about your project..."></textarea>
            </div>

            <button type="submit" class="submit-btn">
              <span>Submit Request</span>
              <i class="fas fa-paper-plane"></i>
            </button>
          </form>

          <div id="form-success" class="success-message">
            <div class="success-icon"><i class="fas fa-check-circle"></i></div>
            <h3>Message Sent!</h3>
            <p>
              Thank you for reaching out. Our team will contact you shortly to
              discuss your project.
            </p>
          </div>
        </div>

        <!-- Contact Sidebar -->
        <div class="contact-sidebar">
          <div class="info-blocks">
            {
              client.phone && (
                <a href={`tel:${client.phone}`} class="info-card">
                  <div class="icon-box">
                    <i class="fas fa-phone-alt" />
                  </div>
                  <div class="info-text">
                    <span>Call Us Anytime</span>
                    <strong>{client.phone}</strong>
                  </div>
                </a>
              )
            }

            {
              client.email && (
                <a href={`mailto:${client.email}`} class="info-card">
                  <div class="icon-box">
                    <i class="fas fa-envelope" />
                  </div>
                  <div class="info-text">
                    <span>Email Our Team</span>
                    <strong>{client.email}</strong>
                  </div>
                </a>
              )
            }

            {
              client.address && (
                <div class="info-card">
                  <div class="icon-box">
                    <i class="fas fa-map-marker-alt" />
                  </div>
                  <div class="info-text">
                    <span>Visit Our Office</span>
                    <strong>
                      {client.address}, {client.city}
                    </strong>
                  </div>
                </div>
              )
            }
          </div>

          <div class="sidebar-widget business-hours">
            <h3>Office Hours</h3>
            <ul>
              <li>
                <span>Monday - Friday:</span>
                <strong>8:00 AM - 6:00 PM</strong>
              </li>
              <li><span>Saturday:</span> <strong>9:00 AM - 4:00 PM</strong></li>
              <li><span>Sunday:</span> <strong>Closed</strong></li>
            </ul>
          </div>

          <div class="sidebar-widget service-areas">
            <h3>Service Areas</h3>
            <div class="area-tags">
              {
                client.serviceArea?.map((area: string) => (
                  <span class="tag">{area}</span>
                ))
              }
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="contact-faq">
    <div class="container">
      <div class="section-header">
        <h2>Frequently Asked Questions</h2>
        <p>Common questions about our services and process.</p>
      </div>
      <div class="faq-grid">
        <div class="faq-item">
          <h4>How quickly can I get an estimate?</h4>
          <p>
            We typically respond to all inquiries within 24 hours and can often
            provide a site visit within 48 hours.
          </p>
        </div>
        <div class="faq-item">
          <h4>Do you offer seasonal maintenance packages?</h4>
          <p>
            Yes, we have comprehensive year-round maintenance plans tailored to
            the specific needs of {client.city} properties.
          </p>
        </div>
        <div class="faq-item">
          <h4>Are you licensed and insured?</h4>
          <p>
            Absolutely. We are fully licensed, bonded, and carry comprehensive
            liability insurance for your peace of mind.
          </p>
        </div>
        <div class="faq-item">
          <h4>Do you handle commercial properties?</h4>
          <p>
            Yes, we manage both residential and commercial landscapes of all
            sizes.
          </p>
        </div>
      </div>
    </div>
  </section>

  <style define:vars={{ primary }}>
    .container {
      max-width: 1300px;
      margin: 0 auto;
      padding: 0 1.5rem;
    }

    /* Hero */
    .contact-hero {
      background:
        linear-gradient(rgba(0, 0, 0, 0.85), rgba(0, 0, 0, 0.85)),
        url("/images/hero_gardener.png");
      background-size: cover;
      background-position: center;
      background-attachment: fixed;
      padding: 140px 0 100px;
      color: #fff;
      text-align: center;
    }
    .hero-content {
      max-width: 800px;
      margin: 0 auto;
    }
    .contact-hero h1 {
      font-size: 4rem;
      font-weight: 900;
      margin-bottom: 1.5rem;
      line-height: 1.1;
      text-transform: uppercase;
      letter-spacing: -1px;
      text-shadow: 0 4px 30px rgba(0, 0, 0, 0.8);
      color: #f0f0f0;
    }
    .contact-hero .text-accent {
      color: #fff;
      text-shadow: 0 0 25px var(--primary);
    }
    .contact-hero .subtitle {
      display: block;
      font-weight: 800;
      letter-spacing: 4px;
      color: var(--primary);
      margin-bottom: 1rem;
      filter: brightness(2.5);
      font-size: 0.9rem;
    }
    .contact-hero p {
      font-size: 1.25rem;
      opacity: 0.9;
      line-height: 1.7;
      font-weight: 300;
    }

    /* Main Section */
    .contact-main {
      padding: 100px 0;
      background: #f8fafc;
    }
    .contact-grid {
      display: grid;
      grid-template-columns: 1fr 400px;
      gap: 4rem;
      align-items: start;
    }

    /* Form */
    .form-wrapper {
      background: #fff;
      border-radius: 40px;
      padding: 60px;
      box-shadow: 0 20px 60px rgba(0, 0, 0, 0.05);
      border: 1px solid #f0f0f0;
    }
    .form-header {
      margin-bottom: 40px;
    }
    .form-header h2 {
      font-size: 2.2rem;
      font-weight: 900;
      color: #111;
      margin-bottom: 0.5rem;
    }
    .form-header p {
      color: #666;
      font-size: 1.1rem;
    }

    .premium-form {
      display: flex;
      flex-direction: column;
      gap: 25px;
    }
    .input-group-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 25px;
    }

    .field {
      display: flex;
      flex-direction: column;
      gap: 10px;
    }
    .field label {
      font-size: 0.85rem;
      font-weight: 800;
      color: #111;
      text-transform: uppercase;
      letter-spacing: 1px;
    }
    .field input,
    .field select,
    .field textarea {
      padding: 1rem 1.2rem;
      border: 1px solid #e2e8f0;
      border-radius: 15px;
      font-size: 1rem;
      background: #fcfcfc;
      transition: 0.3s;
      outline: none;
      width: 100%;
      box-sizing: border-box;
    }
    
    /* Custom Select Styling */
    .custom-select { position: relative; width: 100%; user-select: none; }
    .select-trigger {
      padding: 1rem 1.2rem;
      border: 1px solid #e2e8f0;
      border-radius: 15px;
      background: #fcfcfc;
      cursor: pointer;
      display: flex;
      justify-content: space-between;
      align-items: center;
      transition: 0.3s;
    }
    .custom-select.active .select-trigger { border-color: var(--primary); box-shadow: 0 0 0 4px var(--primary)15; background: #fff; }
    .select-trigger i { transition: 0.3s; font-size: 0.8rem; color: #94a3b8; }
    .custom-select.active .select-trigger i { transform: rotate(180deg); color: var(--primary); }
    
    .options-list {
      position: absolute;
      top: calc(100% + 10px);
      left: 0;
      right: 0;
      background: #fff;
      border: 1px solid #e2e8f0;
      border-radius: 20px;
      box-shadow: 0 20px 40px rgba(0,0,0,0.1);
      z-index: 100;
      opacity: 0;
      visibility: hidden;
      transform: translateY(-10px);
      transition: 0.3s;
      overflow: hidden;
      padding: 10px;
    }
    .custom-select.active .options-list { opacity: 1; visibility: visible; transform: translateY(0); }
    
    .option {
      padding: 12px 20px;
      border-radius: 12px;
      cursor: pointer;
      transition: 0.2s;
      font-size: 0.95rem;
      color: #475569;
    }
    .option:hover { background: var(--primary)10; color: var(--primary); font-weight: 600; }
    .option.selected { background: var(--primary); color: #fff; font-weight: 600; }

    .field input:focus,
    .field select:focus,
    .field textarea:focus {
      border-color: var(--primary);
      box-shadow: 0 0 0 4px var(--primary) 15;
      background: #fff;
    }

    .submit-btn {
      background: var(--primary);
      color: #fff;
      padding: 1.2rem;
      border-radius: 15px;
      font-size: 1.1rem;
      font-weight: 800;
      border: none;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 15px;
      transition: 0.3s;
      text-transform: uppercase;
      letter-spacing: 1px;
      margin-top: 15px;
    }
    .submit-btn:hover {
      transform: translateY(-5px);
      box-shadow: 0 15px 35px var(--primary) 40;
    }

    .success-message {
      display: none;
      text-align: center;
      padding: 40px 0;
    }
    .success-icon {
      font-size: 4rem;
      color: var(--primary);
      margin-bottom: 20px;
    }
    .success-message h3 {
      font-size: 2rem;
      font-weight: 900;
      color: #111;
      margin-bottom: 10px;
    }
    .success-message p {
      font-size: 1.1rem;
      color: #666;
    }

    /* Sidebar */
    .info-blocks {
      display: flex;
      flex-direction: column;
      gap: 20px;
      margin-bottom: 40px;
    }
    .info-card {
      display: flex;
      align-items: center;
      gap: 20px;
      padding: 25px;
      background: #fff;
      border-radius: 25px;
      text-decoration: none;
      border: 1px solid #f0f0f0;
      transition: 0.3s;
    }
    .info-card:hover {
      transform: translateX(10px);
      border-color: var(--primary);
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
    }
    .icon-box {
      width: 55px;
      height: 55px;
      background: var(--primary);
      color: #fff;
      border-radius: 15px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.3rem;
    }
    .info-text span {
      display: block;
      font-size: 0.8rem;
      font-weight: 700;
      color: #888;
      text-transform: uppercase;
      margin-bottom: 3px;
    }
    .info-text strong {
      display: block;
      font-size: 1.1rem;
      color: #111;
      font-weight: 800;
    }

    .sidebar-widget {
      background: #fff;
      border-radius: 30px;
      padding: 35px;
      border: 1px solid #f0f0f0;
      margin-bottom: 30px;
    }
    .sidebar-widget h3 {
      font-size: 1.3rem;
      font-weight: 900;
      color: #111;
      margin-bottom: 20px;
      border-bottom: 2px solid var(--primary);
      display: inline-block;
      padding-bottom: 5px;
    }

    .business-hours ul {
      list-style: none;
      padding: 0;
      margin: 0;
    }
    .business-hours li {
      display: flex;
      justify-content: space-between;
      padding: 12px 0;
      border-bottom: 1px dashed #eee;
      font-size: 0.95rem;
    }
    .business-hours li:last-child {
      border: none;
    }
    .business-hours li span {
      color: #666;
    }
    .business-hours li strong {
      color: #111;
      font-weight: 800;
    }

    .area-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
    }
    .tag {
      background: #f1f5f9;
      color: #475569;
      padding: 8px 16px;
      border-radius: 10px;
      font-size: 0.85rem;
      font-weight: 700;
      border: 1px solid #e2e8f0;
    }

    /* FAQ */
    .contact-faq {
      padding: 100px 0;
      background: #fff;
    }
    .section-header {
      text-align: center;
      margin-bottom: 60px;
    }
    .section-header h2 {
      font-size: 2.8rem;
      font-weight: 900;
      color: #111;
      margin-bottom: 1rem;
    }
    .faq-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 40px;
    }
    .faq-item {
      padding: 30px;
      border-radius: 20px;
      background: #f8fafc;
      border: 1px solid #f0f0f0;
    }
    .faq-item h4 {
      font-size: 1.2rem;
      font-weight: 800;
      color: #111;
      margin-bottom: 12px;
    }
    .faq-item p {
      color: #666;
      line-height: 1.7;
    }

    @media (max-width: 1200px) {
      .contact-hero h1 { font-size: 3.5rem; }
      .contact-grid { gap: 2rem; }
    }
    @media (max-width: 992px) {
      .contact-hero { padding: 100px 0 60px; }
      .contact-hero h1 { font-size: 3rem; }
      .contact-grid { grid-template-columns: 1fr; }
      .contact-sidebar { order: 2; display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
      .form-wrapper { order: 1; padding: 40px; }
      .sidebar-widget { margin-bottom: 0; }
    }
    @media (max-width: 768px) {
      .contact-hero h1 { font-size: 2.2rem; }
      .contact-hero p { font-size: 1.1rem; }
      .contact-sidebar { grid-template-columns: 1fr; }
      .input-group-row { grid-template-columns: 1fr; }
      .form-wrapper { padding: 30px 20px; border-radius: 20px; }
      .section-header h2 { font-size: 2.2rem; }
      .faq-grid { grid-template-columns: 1fr; }
      .form-header h2 { font-size: 1.8rem; }
    }
  </style>

  <script>
    // Custom Select Logic
    const customSelect = document.getElementById('service-select');
    const trigger = customSelect?.querySelector('.select-trigger');
    const triggerText = customSelect?.querySelector('.trigger-text');
    const optionsList = customSelect?.querySelector('.options-list');
    const hiddenInput = document.getElementById('service-hidden') as HTMLInputElement;
    const options = customSelect?.querySelectorAll('.option');

    trigger?.addEventListener('click', () => {
      customSelect?.classList.toggle('active');
    });

    options?.forEach(option => {
      option.addEventListener('click', () => {
        const val = option.getAttribute('data-value') || '';
        const text = option.textContent || '';
        
        if (hiddenInput) hiddenInput.value = val;
        if (triggerText) triggerText.textContent = text;
        
        options.forEach(o => o.classList.remove('selected'));
        option.classList.add('selected');
        
        customSelect?.classList.remove('active');
      });
    });

    // Close when clicking outside
    document.addEventListener('click', (e) => {
      if (!customSelect?.contains(e.target as Node)) {
        customSelect?.classList.remove('active');
      }
    });

    document.getElementById("contact-form")?.addEventListener("submit", (e) => {
      e.preventDefault();
      const form = document.querySelector(".premium-form") as HTMLElement;
      const header = document.querySelector(".form-header") as HTMLElement;
      const success = document.getElementById("form-success") as HTMLElement;

      if (form && success && header) {
        form.style.display = "none";
        header.style.display = "none";
        success.style.display = "block";
      }
    });
  </script>
</Layout>
