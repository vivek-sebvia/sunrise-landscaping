---
import Layout from '../../layouts/Layout.astro'
import { client } from '../../client.config.js'

export async function getStaticPaths() {
  try {
    const res = await fetch(
      `${client.cmsUrl}/api/blog?where[tenant.slug][equals]=${client.tenantSlug}&limit=100`
    )
    const data = await res.json()
    return (data.docs || []).map((post: any) => ({
      params: { slug: post.slug },
      props: { post },
    }))
  } catch {
    return []
  }
}

const { post } = Astro.props
const primary = client.primaryColor || '#2d5a3d'
---

<Layout title={post?.title || 'Blog Post'}>

  <section style={`padding:4rem 1.5rem;background:${primary}12`}>
    <div style="max-width:800px;margin:0 auto">
      <a href="/blog" style={`color:${primary};font-size:0.9rem;font-weight:500`}>← Back to Blog</a>
      <h1 style="font-size:2.25rem;font-weight:800;margin:1rem 0 0.5rem;line-height:1.25">{post?.title || 'Blog Post'}</h1>
      {post?.createdAt && (
        <p style="color:#6b7280;font-size:0.875rem">
          {new Date(post.createdAt).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
        </p>
      )}
    </div>
  </section>

  <section style="padding:3rem 1.5rem">
    <div style="max-width:800px;margin:0 auto">
      {post?.image?.url && (
        <div style="border-radius:12px;overflow:hidden;margin-bottom:2rem;aspect-ratio:16/9">
          <img src={post.image.url} alt={post.title} style="width:100%;height:100%;object-fit:cover" />
        </div>
      )}
      <div style="font-size:1.05rem;line-height:1.8;color:#374151" set:html={post?.content || '<p>Content coming soon.</p>'} />
      <div style={`margin-top:3rem;padding:1.5rem;border-radius:12px;background:${primary}12`}>
        <h3 style="font-weight:700;margin-bottom:0.5rem">Ready to get started?</h3>
        <p style="color:#4b5563;margin-bottom:1rem">Contact {client.name} for a free, no-obligation estimate.</p>
        <a href="/contact" style={`background:${primary};color:#fff;padding:0.6rem 1.5rem;border-radius:8px;font-weight:600`}>Get Free Quote</a>
      </div>
    </div>
  </section>

</Layout>