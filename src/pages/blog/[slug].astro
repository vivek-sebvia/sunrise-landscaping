---
import Layout from "../../layouts/Layout.astro";
import { client } from "../../client.config.js";

export async function getStaticPaths() {
  const localPosts = [
    "spring-landscaping-tips",
    "summer-lawn-care",
    "benefits-of-mulching",
    "tree-trimming-importance",
    "hardscaping-value",
  ];

  let cmsPosts = [];
  try {
    const res = await fetch(
      `${client.cmsUrl}/api/blog?where[tenant.slug][equals]=${client.tenantSlug}&limit=100`,
    );
    const data = await res.json();
    cmsPosts = data.docs || [];
  } catch {}

  const cmsPaths = cmsPosts.map((post: any) => ({
    params: { slug: post.slug },
    props: { post },
  }));

  const localPaths = localPosts.map((slug) => ({
    params: { slug },
    props: {
      post: {
        title: slug
          .split("-")
          .map((w) => w.charAt(0).toUpperCase() + w.slice(1))
          .join(" "),
        content: `
          <p>Professional landscaping is the key to maintaining a beautiful and valuable property in ${client.city}. Whether you are looking for seasonal maintenance or a complete outdoor transformation, our team is here to help.</p>
          <h2>Why Choose Professional Care?</h2>
          <p>Many homeowners try to handle their outdoor maintenance themselves, but the expertise and professional-grade equipment of a specialized team can make a significant difference in the health and longevity of your plants and structures.</p>
          <blockquote>"A well-maintained landscape can increase property value by up to 15% while providing a sanctuary for your family to enjoy."</blockquote>
          <p>From precision lawn mowing to intricate hardscape designs, we treat every project with the same level of care and attention to detail. Our sustainable practices ensure that your garden not only looks great today but continues to thrive for years to come.</p>
          <ul>
            <li>Expert soil analysis and fertilization</li>
            <li>Precision pruning and tree health monitoring</li>
            <li>Customized irrigation solutions</li>
            <li>Premium materials for all hardscaping projects</li>
          </ul>
        `,
        createdAt: new Date().toISOString(),
        category: "Landscaping Tips",
        image: {
          url: `/images/${slug.includes("lawn") ? "lawn_care" : slug.includes("tree") ? "tree_trimming" : slug.includes("mulch") ? "mulching" : slug.includes("hard") ? "hardscaping" : "garden_design"}.png`,
        },
      },
    },
  }));

  return [...cmsPaths, ...localPaths];
}

const { post } = Astro.props;
const primary = client.primaryColor || "#2d5a3d";
---

<Layout title={post?.title || "Blog Post"}>
  <!-- Article Hero -->
  <section class="article-hero">
    <div class="container">
      <div class="hero-content">
        <a href="/blog" class="back-link"
          ><i class="fas fa-arrow-left"></i> Back to Insights</a
        >
        <div class="meta-tags">
          <span class="category-tag">{post?.category || "Landscaping"}</span>
          <span class="read-time">8 MIN READ</span>
        </div>
        <h1>{post?.title}</h1>
        <div class="author-meta">
          <div class="author-img">
            <i class="fas fa-user-circle"></i>
          </div>
          <div class="author-info">
            <span class="author-name">{client.name} Team</span>
            <span class="post-date"
              >{
                post?.createdAt
                  ? new Date(post.createdAt).toLocaleDateString("en-US", {
                      month: "long",
                      day: "numeric",
                      year: "numeric",
                    })
                  : "Recently"
              }</span
            >
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Article Content Section -->
  <section class="article-body-section">
    <div class="container">
      <div class="article-layout">
        <!-- Main Content -->
        <main class="main-content">
          {
            post?.image?.url && (
              <div class="featured-image">
                <img src={post.image.url} alt={post.title} />
                <div class="image-caption">
                  Expert property enhancement services in {client.city}
                </div>
              </div>
            )
          }

          <div class="content-wrapper" set:html={post?.content} />

          <!-- Article Footer / Share -->
          <div class="article-footer">
            <div class="share-box">
              <span>Share this article:</span>
              <div class="share-btns">
                <a href="#"><i class="fab fa-facebook-f"></i></a>
                <a href="#"><i class="fab fa-twitter"></i></a>
                <a href="#"><i class="fab fa-linkedin-in"></i></a>
              </div>
            </div>
          </div>
        </main>

        <!-- Sidebar -->
        <aside class="article-sidebar">
          <div class="sidebar-widget contact-widget">
            <h3>Need Expert Advice?</h3>
            <p>Our team is ready to help you transform your outdoor space.</p>
            <a href="/contact" class="btn btn-primary">Get A Free Quote</a>
            <div class="sidebar-contact">
              <i class="fas fa-phone-alt"></i>
              <span>{client.phone}</span>
            </div>
          </div>

          <div class="sidebar-widget">
            <h3>Related Services</h3>
            <ul class="service-list">
              {
                client.services.slice(0, 5).map((s: string) => (
                  <li>
                    <a href="/services">
                      <i class="fas fa-chevron-right" /> {s}
                    </a>
                  </li>
                ))
              }
            </ul>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <style define:vars={{ primary }}>
    .container {
      max-width: 1400px;
      margin: 0 auto;
      padding: 0 1.5rem;
    }

    /* Hero Section */
    .article-hero {
      background:
        linear-gradient(rgba(0, 0, 0, 0.85), rgba(0, 0, 0, 0.85)),
        url("/images/hero_gardener.png");
      background-size: cover;
      background-position: center;
      background-attachment: fixed;
      padding: 120px 0 80px;
      color: #fff;
    }
    .hero-content {
      max-width: 900px;
    }
    .back-link {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      color: var(--primary);
      text-decoration: none;
      font-weight: 700;
      font-size: 0.9rem;
      text-transform: uppercase;
      letter-spacing: 1px;
      margin-bottom: 2rem;
      filter: brightness(2);
    }
    .meta-tags {
      display: flex;
      gap: 20px;
      margin-bottom: 1.5rem;
      align-items: center;
    }
    .category-tag {
      background: var(--primary);
      color: #fff;
      padding: 6px 15px;
      border-radius: 8px;
      font-size: 0.75rem;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 1px;
    }
    .read-time {
      font-size: 0.8rem;
      font-weight: 700;
      opacity: 0.6;
      letter-spacing: 1px;
    }

    .article-hero h1 {
      font-size: 4rem;
      font-weight: 900;
      line-height: 1.1;
      margin-bottom: 2.5rem;
      color: #f0f0f0;
    }

    .author-meta {
      display: flex;
      align-items: center;
      gap: 15px;
    }
    .author-img {
      font-size: 2.5rem;
      color: var(--primary);
      filter: brightness(1.5);
    }
    .author-info {
      display: flex;
      flex-direction: column;
    }
    .author-name {
      font-weight: 800;
      font-size: 1.1rem;
    }
    .post-date {
      font-size: 0.9rem;
      opacity: 0.7;
    }

    /* Layout */
    .article-body-section {
      padding: 80px 0;
      background: #fff;
    }
    .article-layout {
      display: grid;
      grid-template-columns: 1fr 350px;
      gap: 80px;
    }

    /* Content */
    .featured-image {
      border-radius: 40px;
      overflow: hidden;
      margin-bottom: 3rem;
      box-shadow: 0 25px 60px rgba(0, 0, 0, 0.1);
    }
    .featured-image img {
      width: 100%;
      height: auto;
      object-fit: cover;
    }
    .image-caption {
      padding: 15px 30px;
      background: #f8fafc;
      color: #666;
      font-size: 0.9rem;
      border-bottom: 3px solid var(--primary);
      font-style: italic;
    }

    .content-wrapper {
      font-size: 1.2rem;
      line-height: 1.8;
      color: #333;
    }
    .content-wrapper :global(h2) {
      font-size: 2.5rem;
      font-weight: 900;
      margin: 4rem 0 2rem;
      color: #111;
    }
    .content-wrapper :global(p) {
      margin-bottom: 2rem;
    }
    .content-wrapper :global(blockquote) {
      border-left: 5px solid var(--primary);
      padding: 30px 40px;
      background: #f8fafc;
      font-style: italic;
      font-size: 1.4rem;
      color: #111;
      margin: 3rem 0;
      border-radius: 0 20px 20px 0;
    }
    .content-wrapper :global(ul) {
      margin-bottom: 2rem;
      padding-left: 1.5rem;
      list-style: none;
    }
    .content-wrapper :global(li) {
      margin-bottom: 1rem;
      position: relative;
    }
    .content-wrapper :global(li::before) {
      content: "✓";
      position: absolute;
      left: -1.5rem;
      color: var(--primary);
      font-weight: 900;
    }

    /* Article Footer */
    .article-footer {
      margin-top: 5rem;
      padding-top: 3rem;
      border-top: 1px solid #eee;
    }
    .share-box {
      display: flex;
      align-items: center;
      gap: 20px;
      font-weight: 800;
      color: #111;
    }
    .share-btns {
      display: flex;
      gap: 10px;
    }
    .share-btns a {
      width: 45px;
      height: 45px;
      border-radius: 50%;
      background: #f0f0f0;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #333;
      transition: 0.3s;
      text-decoration: none;
    }
    .share-btns a:hover {
      background: var(--primary);
      color: #fff;
      transform: translateY(-3px);
    }

    /* Sidebar */
    .sidebar-widget {
      background: #f8fafc;
      border-radius: 30px;
      padding: 40px;
      margin-bottom: 40px;
      border: 1px solid #f0f0f0;
    }
    .contact-widget {
      background: #111;
      color: #fff;
      border: none;
    }
    .sidebar-widget h3 {
      font-size: 1.5rem;
      font-weight: 900;
      margin-bottom: 1.5rem;
      color: #f0f0f0;
    }
    .contact-widget p {
      opacity: 0.8;
      margin-bottom: 2rem;
    }
    .sidebar-contact {
      margin-top: 2rem;
      display: flex;
      align-items: center;
      gap: 10px;
      font-weight: 800;
      color: var(--primary);
      font-size: 1.2rem;
    }

    .service-list {
      list-style: none;
      padding: 0;
    }
    .service-list li {
      margin-bottom: 1rem;
    }
    .service-list a {
      text-decoration: none;
      color: #444;
      font-weight: 600;
      display: flex;
      align-items: center;
      gap: 10px;
      transition: 0.3s;
    }
    .service-list a:hover {
      color: var(--primary);
      transform: translateX(5px);
    }

    /* Buttons */
    .btn {
      padding: 1.1rem 2.5rem;
      border-radius: 12px;
      font-weight: 800;
      text-decoration: none;
      transition: 0.4s;
      display: inline-flex;
      align-items: center;
      gap: 0.75rem;
      cursor: pointer;
      border: none;
      text-transform: uppercase;
      letter-spacing: 1px;
      font-size: 0.9rem;
      width: 100%;
      justify-content: center;
    }
    .btn-primary {
      background: var(--primary);
      color: #fff;
    }

    @media (max-width: 1024px) {
      .article-layout {
        grid-template-columns: 1fr;
      }
      .article-hero h1 {
        font-size: 3rem;
      }
    }
  </style>
</Layout>
