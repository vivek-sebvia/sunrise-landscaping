---
import Layout from "../layouts/Layout.astro";
import { client } from "../client.config.js";
const primary = client.primaryColor || "#2d5a3d";

const stats = [
  { number: "15+", label: "Years of Experience", icon: "fa-calendar-check" },
  { number: "500+", label: "Projects Completed", icon: "fa-check-circle" },
  { number: "100%", label: "Satisfaction Rate", icon: "fa-smile" },
  { number: "24/7", label: "Support Available", icon: "fa-headset" },
];

const values = [
  {
    icon: "fa-gem",
    title: "Excellence",
    desc: "We strive for perfection in every blade of grass and every stone we place.",
  },
  {
    icon: "fa-shield-alt",
    title: "Reliability",
    desc: "You can count on us to be there on time and deliver exactly what we promised.",
  },
  {
    icon: "fa-leaf",
    title: "Sustainability",
    desc: "We use eco-friendly practices to keep your garden healthy and the planet happy.",
  },
  {
    icon: "fa-handshake",
    title: "Integrity",
    desc: "Honest pricing and transparent communication are the pillars of our business.",
  },
];
---

<Layout
  title="About Us"
  description={`Learn about ${client.name} — trusted ${client.industry} professionals in ${client.city}, ${client.state}.`}
>
  <!-- Premium Page Header -->
  <section class="about-hero">
    <div class="container">
      <div class="about-hero-content">
        <span class="subtitle">ESTABLISHED {new Date().getFullYear() - 10}</span
        >
        <h1>Dedicated to <span class="text-accent">Visual Excellence</span></h1>
        <p>
          Discover the passion and craftsmanship behind {client.name}. We don't
          just maintain gardens; we create outdoor experiences.
        </p>
      </div>
    </div>
  </section>

  <!-- Story Section -->
  <section class="about-story">
    <div class="container">
      <div class="story-grid">
        <div class="story-image">
          <img src="/images/landscaping_team.png" alt="Our Team" />
          <div class="image-accent"></div>
        </div>
        <div class="story-content">
          <h2 class="section-title">Our Story</h2>
          <p class="lead">
            {client.name} is a locally owned and operated {client.industry} company
            serving {client.city}, {client.state} and the surrounding areas.
          </p>
          <div class="story-body">
            <p>
              Founded on the principles of hard work and artistic vision, we
              have grown from a small neighborhood crew into {client.city}'s
              most trusted landscaping partner. We treat every property as if it
              were our own, ensuring meticulous attention to detail.
            </p>
            <p>
              Our team of licensed professionals brings years of hands-on
              experience to every project. Whether it's a small seasonal cleanup
              or a complex hardscaping installation, we bring the same level of
              dedication and premium quality.
            </p>
          </div>
          <div class="story-features">
            <div class="feature-item">
              <i class="fas fa-check-circle"></i>
              <span>Fully Licensed & Insured</span>
            </div>
            <div class="feature-item">
              <i class="fas fa-check-circle"></i>
              <span>Certified Technicians</span>
            </div>
            <div class="feature-item">
              <i class="fas fa-check-circle"></i>
              <span>Free Consultation</span>
            </div>
          </div>
          <div class="btn-group">
            <a href="/contact" class="btn btn-primary">Work With Us</a>
            <a href={`tel:${client.phone}`} class="btn btn-outline"
              >Call: {client.phone}</a
            >
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats Section (Premium Parallax Style) -->
  <section class="about-stats">
    <div class="container">
      <div class="stats-grid">
        {
          stats.map((stat) => (
            <div class="stat-card">
              <i class={`fas ${stat.icon}`} />
              <div class="stat-number">{stat.number}</div>
              <div class="stat-label">{stat.label}</div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Values Section -->
  <section class="about-values">
    <div class="container">
      <div class="text-center mb-5">
        <h2 class="section-title">Core Values</h2>
        <p class="section-subtitle">
          The principles that guide every project we undertake.
        </p>
      </div>
      <div class="values-grid">
        {
          values.map((v) => (
            <div class="value-card">
              <div class="value-icon">
                <i class={`fas ${v.icon}`} />
              </div>
              <h3>{v.title}</h3>
              <p>{v.desc}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="about-cta">
    <div class="container">
      <div class="cta-box">
        <h2>Ready to transform your outdoor space?</h2>
        <p>
          Join hundreds of satisfied homeowners in {client.city}. Let's build
          something beautiful together.
        </p>
        <div class="cta-btns">
          <a href="/contact" class="btn btn-light">Get My Free Quote</a>
          <a href="/services" class="btn btn-outline-light">Explore Services</a>
        </div>
      </div>
    </div>
  </section>

  <style define:vars={{ primary }}>
    /* Hero Section */
    .about-hero {
      background:
        linear-gradient(rgba(0, 0, 0, 0.8), rgba(0, 0, 0, 0.8)),
        url("/images/garden_design.png");
      background-size: cover;
      background-position: center;
      padding: 140px 0;
      color: #fff;
      text-align: center;
    }
    .about-hero-content {
      max-width: 800px;
      margin: 0 auto;
    }
    .about-hero h1 {
      font-size: 4.5rem;
      font-weight: 800;
      line-height: 1.1;
      margin-bottom: 1.5rem;
      text-shadow: 0 4px 20px rgba(0, 0, 0, 0.6);
      color: #fff;
    }
    .about-hero .text-accent {
      color: #fff;
      text-shadow: 0 0 20px var(--primary);
    }
    .about-hero .subtitle {
      display: block;
      font-weight: 700;
      letter-spacing: 3px;
      color: var(--primary);
      margin-bottom: 1rem;
      filter: brightness(2.5);
    }
    .about-hero p {
      font-size: 1.25rem;
      opacity: 0.9;
      line-height: 1.6;
    }

    /* Story Section */
    .about-story {
      padding: 100px 0;
      background: #fff;
    }
    .story-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 80px;
      align-items: center;
    }
    .story-image {
      position: relative;
    }
    .story-image img {
      width: 100%;
      border-radius: 20px;
      box-shadow: 0 30px 60px rgba(0, 0, 0, 0.1);
      position: relative;
      z-index: 2;
    }
    .image-accent {
      position: absolute;
      width: 100%;
      height: 100%;
      border: 10px solid var(--primary);
      border-radius: 20px;
      top: -30px;
      left: -30px;
      z-index: 1;
      opacity: 0.2;
    }
    .story-content .section-title {
      font-size: 2.5rem;
      margin-bottom: 1.5rem;
      color: #111;
    }
    .story-content .lead {
      font-size: 1.2rem;
      font-weight: 600;
      color: #444;
      margin-bottom: 1.5rem;
    }
    .story-body p {
      color: #666;
      line-height: 1.8;
      margin-bottom: 1.5rem;
    }
    .story-features {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
      margin-bottom: 2.5rem;
    }
    .feature-item {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      font-weight: 600;
      color: #333;
    }
    .feature-item i {
      color: var(--primary);
    }

    /* Stats Section */
    .about-stats {
      background:
        linear-gradient(rgba(0, 0, 0, 0.92), rgba(0, 0, 0, 0.92)),
        url("/images/hardscaping.png");
      background-size: cover;
      background-attachment: fixed;
      padding: 100px 0;
      color: #fff;
    }
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 40px;
      text-align: center;
    }
    .stat-card i {
      font-size: 2.5rem;
      color: var(--primary);
      margin-bottom: 1.5rem;
      opacity: 0.8;
    }
    .stat-number {
      font-size: 4.5rem;
      font-weight: 800;
      color: #fff;
      text-shadow: 0 0 15px var(--primary);
      margin-bottom: 0.5rem;
    }
    .stat-label {
      font-size: 1.1rem;
      color: rgba(255, 255, 255, 0.9);
      font-weight: 500;
    }

    /* Values Section */
    .about-values {
      padding: 100px 0;
      background: #f8fafc;
    }
    .values-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 30px;
    }
    .value-card {
      background: #fff;
      padding: 40px;
      border-radius: 20px;
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
      transition: 0.4s;
      border-bottom: 4px solid transparent;
    }
    .value-card:hover {
      transform: translateY(-10px);
      border-color: var(--primary);
      box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
    }
    .value-icon {
      width: 60px;
      height: 60px;
      background: rgba(var(--primary-rgb), 0.1);
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: 12px;
      margin-bottom: 1.5rem;
    }
    .value-icon i {
      font-size: 1.5rem;
      color: var(--primary);
    }
    .value-card h3 {
      font-size: 1.5rem;
      margin-bottom: 1rem;
      color: #111;
    }
    .value-card p {
      color: #666;
      line-height: 1.6;
      font-size: 0.95rem;
    }

    /* CTA Section */
    .about-cta {
      padding-bottom: 100px;
      background: #f8fafc;
    }
    .cta-box {
      background: #111;
      padding: 100px;
      border-radius: 30px;
      color: #fff;
      text-align: center;
      box-shadow: 0 30px 60px rgba(0, 0, 0, 0.2);
      position: relative;
      overflow: hidden;
    }
    .cta-box::before {
      content: "";
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: linear-gradient(135deg, var(--primary), #000);
      opacity: 0.8;
      z-index: 1;
    }
    .cta-box * {
      position: relative;
      z-index: 2;
    }
    .cta-box h2 {
      font-size: 3.5rem;
      font-weight: 800;
      margin-bottom: 1.5rem;
      color: #fff;
    }
    .cta-box p {
      font-size: 1.25rem;
      opacity: 0.9;
      margin-bottom: 2.5rem;
      max-width: 700px;
      margin-left: auto;
      margin-right: auto;
    }
    .cta-btns {
      display: flex;
      gap: 1.5rem;
      justify-content: center;
      flex-wrap: wrap;
    }

    /* Buttons */
    .btn {
      padding: 1rem 2.5rem;
      border-radius: 10px;
      font-weight: 700;
      text-decoration: none;
      transition: 0.3s;
      display: inline-block;
      cursor: pointer;
      border: none;
    }
    .btn-primary {
      background: var(--primary);
      color: #fff;
    }
    .btn-primary:hover {
      transform: translateY(-3px);
      box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1);
      filter: brightness(1.1);
    }
    .btn-outline {
      border: 2px solid var(--primary);
      color: var(--primary);
    }
    .btn-outline:hover {
      background: var(--primary);
      color: #fff;
    }
    .btn-light {
      background: #fff;
      color: #111;
    }
    .btn-light:hover {
      transform: translateY(-3px);
      box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1);
    }
    .btn-outline-light {
      border: 2px solid #fff;
      color: #fff;
    }
    .btn-outline-light:hover {
      background: #fff;
      color: #111;
    }

    @media (max-width: 1200px) {
      .about-hero h1 { font-size: 3.5rem; }
      .story-grid { gap: 40px; }
      .stat-number { font-size: 3.5rem; }
    }
    @media (max-width: 992px) {
      .about-hero { padding: 100px 0; }
      .about-hero h1 { font-size: 3rem; }
      .story-grid { grid-template-columns: 1fr; }
      .story-image { order: -1; }
      .image-accent { display: none; }
      .about-stats { padding: 60px 0; }
      .values-grid { grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); }
      .cta-box { padding: 60px 30px; }
      .cta-box h2 { font-size: 2.5rem; }
    }
    @media (max-width: 768px) {
      .about-hero h1 { font-size: 2.2rem; }
      .about-hero p { font-size: 1.1rem; }
      .story-content .section-title { font-size: 2rem; }
      .story-features { grid-template-columns: 1fr; }
      .stat-number { font-size: 2.8rem; }
      .cta-box h2 { font-size: 2rem; }
      .cta-btns { flex-direction: column; width: 100%; gap: 1rem; }
      .btn { width: 100%; text-align: center; }
    }
  </style>
</Layout>
