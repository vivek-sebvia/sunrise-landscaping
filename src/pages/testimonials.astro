---
import Layout from '../layouts/Layout.astro'
import { client } from '../client.config.js'

let testimonials = []
try {
  const res = await fetch(`${client.cmsUrl}/api/testimonials?where[tenant.slug][equals]=${client.tenantSlug}&limit=20`)
  testimonials = (await res.json()).docs || []
} catch {}

const primary = client.primaryColor || '#2d5a3d'
---

<Layout title="Reviews" description={`Reviews from satisfied customers of ${client.name}.`}>

  <section style={`padding:4rem 1.5rem;background:${primary}12;text-align:center`}>
    <div style="max-width:1200px;margin:0 auto">
      <h1 style="font-size:2.5rem;font-weight:800;margin-bottom:1rem">Customer Reviews</h1>
      <p style="color:#6b7280;font-size:1.05rem">See what our customers say about our work.</p>
    </div>
  </section>

  <section style="padding:4rem 1.5rem">
    <div style="max-width:1200px;margin:0 auto">
      {testimonials.length > 0 ? (
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:1.25rem">
          {testimonials.map((t: any) => (
            <div style="padding:1.5rem;border-radius:12px;border:1px solid #e5e7eb">
              <div style="color:#facc15;font-size:1.2rem;margin-bottom:0.75rem">★★★★★</div>
              <p style="color:#374151;font-style:italic;margin-bottom:1rem;line-height:1.7">"{t.text || t.content}"</p>
              <div style="display:flex;align-items:center;gap:0.75rem">
                <div style={`width:38px;height:38px;border-radius:50%;background:${primary};color:#fff;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:0.875rem;flex-shrink:0`}>
                  {(t.name || t.author || 'A').charAt(0).toUpperCase()}
                </div>
                <div>
                  <p style="font-weight:700;font-size:0.9rem">{t.name || t.author}</p>
                  {t.location && <p style="font-size:0.8rem;color:#6b7280">{t.location}</p>}
                </div>
              </div>
            </div>
          ))}
        </div>
      ) : (
        <div style="text-align:center;padding:4rem;color:#6b7280">
          <div style="font-size:4rem;margin-bottom:1rem">⭐</div>
          <p style="font-size:1.1rem;font-weight:500">Reviews coming soon!</p>
        </div>
      )}
    </div>
  </section>

  <section style={`padding:4rem 1.5rem;background:${primary};color:#fff;text-align:center`}>
    <div style="max-width:700px;margin:0 auto">
      <h2 style="font-size:1.75rem;font-weight:700;margin-bottom:1rem">Join Our Happy Customers</h2>
      <a href="/contact" style="background:#fff;color:#111;padding:0.75rem 2rem;border-radius:10px;font-weight:700">Get Free Quote</a>
    </div>
  </section>

</Layout>