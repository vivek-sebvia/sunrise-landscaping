---
import '../styles/global.css'
import { client } from '../client.config.js'
const { title, description } = Astro.props
const fullTitle = `${title} | ${client.name}`
const metaDesc = description || client.tagline
const currentPath = Astro.url.pathname
const primary = client.primaryColor || '#2d5a3d'
const isHome = currentPath === '/' || currentPath === '' || currentPath === '/index.html'
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{fullTitle}</title>
  <meta name="description" content={metaDesc} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Marcellus&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  
  <!-- Spline & Motion Tools -->
  <script type="module" src="https://unpkg.com/@splinetool/viewer@1.0.93/build/spline-viewer.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/motion@11.11.13/dist/motion.js"></script>
  <script src="https://unpkg.com/lenis@1.1.13/dist/lenis.min.js"></script>
  <style set:html={`
    :root {
      --primary: ${primary};
      --primary-rgb: ${parseInt(primary.slice(1,3), 16)}, ${parseInt(primary.slice(3,5), 16)}, ${parseInt(primary.slice(5,7), 16)};
      --secondary: #1a1a1a;
      --dark-green: #11322a;
      --text-main: #333333;
      --text-light: #666666;
      --bg-light: #f8f9f8;
      --font-heading: 'Outfit', sans-serif;
      --font-body: 'Inter', sans-serif;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: var(--font-body); color: var(--text-main); background: #fff; line-height: 1.6; }
    a { text-decoration: none; transition: all 0.3s ease; color: inherit; }
    img { max-width: 100%; height: auto; }
    h1, h2, h3, h4, h5 { font-family: var(--font-heading); color: var(--secondary); line-height: 1.2; }

    /* Lenis Smooth Scroll Recommended CSS */
    html.lenis, html.lenis body { height: auto; }
    .lenis.lenis-smooth { scroll-behavior: auto !important; }
    .lenis.lenis-smooth [data-lenis-prevent] { overscroll-behavior: contain; }
    .lenis.lenis-stopped { overflow: hidden; }
    .lenis.lenis-scrolling iframe { pointer-events: none; }
    
    .container { max-width: 1320px; margin: 0 auto; padding: 0 1.5rem; }
    
    /* Top Bar */
    /* Top Bar */
    .top-bar { background: var(--dark-green); color: #fff; padding: 0.75rem 0; font-size: 0.85rem; font-weight: 500; height: 40px; box-sizing: border-box; }
    .top-bar-content { display: flex; justify-content: space-between; align-items: center; }
    .top-bar-left { display: flex; gap: 2rem; }
    .top-bar-left span { display: flex; align-items: center; gap: 0.5rem; }
    .top-bar-left i { color: var(--primary); }
    .top-bar-right { display: flex; align-items: center; gap: 2rem; }
    .top-bar-links { display: flex; gap: 1rem; }
    .top-bar-links a { opacity: 0.8; }
    .top-bar-links a:hover { opacity: 1; }
    .top-bar-social { display: flex; gap: 1rem; margin-left: 1rem; }
    .top-bar-social a { opacity: 0.8; }
    .top-bar-social a:hover { color: var(--primary); opacity: 1; }
    
    /* Header */
    /* Header Overlay */
    header { background: transparent; z-index: 100; position: absolute; top: 40px; left: 0; right: 0; transition: 0.3s; }
    header.sticky { position: fixed; top: 0; background: #fff; box-shadow: 0 10px 30px rgba(0,0,0,0.05); }
    .header-main { display: flex; align-items: center; height: 100px; }
    .logo { font-size: 1.5rem; font-weight: 800; color: #111; display: flex; align-items: center; gap: 0.75rem; flex: 0 0 250px; }
    .logo-img { width: 40px; height: 40px; background: var(--primary); border-radius: 4px; display: flex; align-items: center; justify-content: center; color: #fff; }
    
    nav.desktop-only { display: flex; align-items: center; gap: 2rem; flex: 1; justify-content: center; }
    .nav-link { font-weight: 700; font-size: 1rem; color: #111; position: relative; padding: 0.5rem 0; }
    .nav-link::after { content: ''; position: absolute; bottom: -2px; left: 0; width: 0; height: 3px; background: var(--primary); transition: width 0.3s ease; }
    .nav-link:hover::after, .nav-link.active::after { width: 100%; }
    .nav-link:hover, .nav-link.active { color: var(--primary); }
    
    .header-right { display: flex; align-items: center; gap: 2rem; }
    .search-icon { font-size: 1.1rem; cursor: pointer; color: #111; }
    .btn-quote { background: var(--primary); color: #fff; padding: 1.1rem 2.2rem; font-weight: 700; font-size: 1rem; border: none; cursor: pointer; transition: 0.3s; }
    .btn-quote:hover { background: var(--dark-green); }
    
    .mobile-only { display: none; }
    
    .contact-block { display: flex; align-items: center; gap: 0.75rem; }
    .contact-icon { width: 45px; height: 45px; border-radius: 50%; border: 1px solid #eee; display: flex; align-items: center; justify-content: center; color: var(--primary); font-size: 1.2rem; }
    .contact-info { display: flex; flex-direction: column; }
    .contact-label { font-size: 0.75rem; font-weight: 600; color: #777; margin-bottom: 2px; }
    .contact-value { font-size: 0.95rem; font-weight: 800; color: #111; }
    
    /* Internal Page Header (Transparent & White Text) */
    header.is-internal:not(.sticky) .nav-link,
    header.is-internal:not(.sticky) .logo,
    header.is-internal:not(.sticky) .contact-value,
    header.is-internal:not(.sticky) .search-icon { color: #fff; }
    header.is-internal:not(.sticky) .logo-img { background: #fff; color: var(--primary); }
    header.is-internal:not(.sticky) .contact-label { color: rgba(255,255,255,0.7); }
    header.is-internal:not(.sticky) .contact-icon { border-color: rgba(255,255,255,0.3); color: #fff; }
    header.is-internal:not(.sticky) .nav-link::after { background: #fff; }

    /* Mobile Nav */
    #mobile-nav { position: fixed; top: 0; right: -300px; width: 300px; height: 100%; background: #fff; z-index: 1000; transition: 0.3s; padding: 2rem; box-shadow: -10px 0 30px rgba(0,0,0,0.1); }
    #mobile-nav.open { right: 0; }
    .mobile-overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 999; display: none; }
    .mobile-overlay.open { display: block; }

    /* Footer */
    footer { background: var(--primary); color: #fff; position: relative; overflow: hidden; }
    .footer-top { padding: 80px 0 40px; }
    .footer-flex { display: flex; gap: 4rem; justify-content: space-between; flex-wrap: wrap; }
    
    .footer-left { flex: 0 0 350px; }
    .footer-logo { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 2rem; color: #fff; font-size: 1.5rem; font-weight: 800; line-height: 1.1; }
    .footer-logo i { font-size: 2rem; }
    .footer-logo span { display: block; font-size: 0.75rem; font-weight: 500; color: rgba(255,255,255,0.7); font-family: var(--font-body); letter-spacing: 0px; text-transform: none; }
    
    .subscribe-box { background: rgba(0,0,0,0.25); padding: 2rem; border-radius: 4px; }
    .subscribe-box h4 { color: #fff; font-size: 0.9rem; margin-bottom: 1rem; font-family: var(--font-body); }
    .subscribe-form { display: flex; height: 45px; }
    .subscribe-form input { flex: 1; background: rgba(0,0,0,0.3); border: none; padding: 0 1rem; color: #fff; font-size: 0.85rem; outline: none; }
    .subscribe-form input::placeholder { color: rgba(255,255,255,0.5); }
    .subscribe-form button { background: #4CAF50; color: #fff; border: none; padding: 0 1.25rem; font-weight: 700; cursor: pointer; transition: 0.3s; }
    .subscribe-form button:hover { background: #45a049; }
    
    .footer-right { flex: 1; display: flex; flex-direction: column; }
    .footer-links-grid { display: grid; grid-template-columns: 1fr 1fr 1.5fr; gap: 2rem; margin-bottom: 3rem; }
    .footer-col h4 { color: #fff; font-size: 1.1rem; margin-bottom: 1.5rem; }
    .footer-col ul { list-style: none; }
    .footer-col li { margin-bottom: 0.8rem; }
    .footer-col a, .footer-col p { color: rgba(255,255,255,0.7); font-size: 0.9rem; transition: 0.3s; }
    .footer-col a:hover { color: #fff; }
    
    .footer-contact-row { display: flex; justify-content: space-between; align-items: center; border-top: 1px solid rgba(255,255,255,0.1); padding-top: 2rem; flex-wrap: wrap; gap: 1.5rem; }
    .footer-socials { display: flex; gap: 0.5rem; }
    .footer-socials a { width: 40px; height: 40px; background: rgba(255,255,255,0.1); display: flex; align-items: center; justify-content: center; color: #fff; border-radius: 4px; transition: 0.3s; }
    .footer-socials a:hover { background: #4CAF50; }
    
    .footer-call { display: flex; align-items: center; gap: 1rem; }
    .footer-call i { font-size: 2rem; color: rgba(255,255,255,0.6); }
    .footer-call-text span { display: block; font-size: 0.8rem; color: rgba(255,255,255,0.7); font-weight: 600; margin-bottom: 2px; }
    .footer-call-text strong { display: block; font-size: 1.2rem; color: #fff; }
    
    .footer-bottom { background: rgba(255,255,255,0.05); padding: 1.5rem 0; position: relative; }
    .footer-bottom-flex { display: flex; justify-content: space-between; align-items: center; color: rgba(255,255,255,0.6); font-size: 0.85rem; padding-right: 70px; }
    .footer-bottom-links a { color: rgba(255,255,255,0.6); transition: 0.3s; }
    .footer-bottom-links a:hover { color: #fff; }
    
    .scroll-top { position: absolute; right: 0; top: -25px; width: 50px; height: 50px; background: #4CAF50; border: 3px solid #fff; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #fff; font-size: 1.2rem; cursor: pointer; transition: 0.3s; z-index: 10; }
    .scroll-top:hover { transform: translateY(-5px); }



    .footer-bg-left { position: absolute; left: 0; top: 10%; width: 300px; opacity: 0.05; pointer-events: none; }
    .footer-bg-right { position: absolute; right: 0; bottom: 0; width: 350px; opacity: 0.1; pointer-events: none; }
    
    @media (max-width: 992px) {
      .footer-flex { flex-direction: column; }
      .footer-left { flex: none; width: 100%; }
    }
    @media (max-width: 768px) {
      .footer-links-grid { grid-template-columns: 1fr; }
      .footer-bottom-flex { flex-direction: column; gap: 1rem; text-align: center; }
    }
    
    @media (max-width: 1200px) {
      nav.desktop-only { gap: 1.2rem; }
      .header-right { gap: 1rem; }
      .btn-quote { padding: 1rem 1.5rem; }
      .contact-block { display: none; }
    }
    @media (max-width: 992px) {
      .desktop-only { display: none !important; }
      .mobile-only { display: block !important; }
      .header-main { justify-content: space-between; }
    }
    @media (max-width: 768px) {
      .top-bar-left span:not(:first-child) { display: none; }
      .top-bar-right { display: none; }
    }
  `}></style>
</head>
<body style="min-height:100vh; display:flex; flex-direction:column">

  <div class="top-bar">
    <div class="container top-bar-content">
      <div class="top-bar-left">
        <span><i class="fas fa-clock"></i> Mon to Sat: 08:00 am to 06:00 pm</span>
        <span><i class="fas fa-envelope"></i> {client.email}</span>
      </div>
      <div class="top-bar-right">
        <div class="top-bar-links">
          <a href="#">Our Faqs</a>
          <span>/</span>
          <a href="#">Pricing</a>
          <span>/</span>
          <a href="/contact">Contact</a>
        </div>
        <div class="top-bar-social">
          <a href="#"><i class="fab fa-facebook-f"></i></a>
          <a href="#"><i class="fab fa-twitter"></i></a>
          <a href="#"><i class="fab fa-pinterest-p"></i></a>
          <a href="#"><i class="fab fa-instagram"></i></a>
        </div>
      </div>
    </div>
  </div>

  <header class={!isHome ? 'is-internal' : ''}>
    <div class="container header-main">
      <a href="/" class="logo">
        <div class="logo-img">
          <i class="fas fa-leaf"></i>
        </div>
        <div style="display:flex; flex-direction:column; line-height:1.1">
          <span style="font-size:1.4rem; font-weight:800; letter-spacing:-0.5px;">{client.name.split(' ')[0]}</span>
          <span style="font-size:0.75rem; font-weight:600; text-transform:uppercase; color:var(--text-light); letter-spacing:1px;">Landscape Garden</span>
        </div>
      </a>
      
      <nav class="desktop-only">
        <a href="/" class={`nav-link${currentPath==='/'?' active':''}`}>Home</a>
        <a href="/about" class={`nav-link${currentPath==='/about'?' active':''}`}>About</a>
        <a href="/services" class={`nav-link${currentPath==='/services'?' active':''}`}>Services</a>
        <a href="/gallery" class={`nav-link${currentPath==='/gallery'?' active':''}`}>Gallery</a>
        <a href="/testimonials" class={`nav-link${currentPath==='/testimonials'?' active':''}`}>Reviews</a>
        <a href="/blog" class={`nav-link${currentPath==='/blog'?' active':''}`}>Blog</a>
        <a href="/contact" class={`nav-link${currentPath==='/contact'?' active':''}`}>Contact</a>
      </nav>

      <div class="header-right">
        <a href="/contact" class="btn-quote desktop-only">Get A Quote</a>
        <div class="contact-block">
          <div class="contact-icon">
            <i class="fas fa-phone-alt"></i>
          </div>
          <div class="contact-info">
            <span class="contact-label">Call Anytime</span>
            <span class="contact-value">{client.phone}</span>
          </div>
        </div>
        <button id="menu-btn" class="mobile-only" style="background:none;border:none;cursor:pointer;padding:0.5rem">
          <svg width="32" height="32" fill="none" stroke="#111" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
        </button>
      </div>
    </div>
  </header>

  <div class="mobile-overlay" id="overlay"></div>
  <div id="mobile-nav">
    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:2rem;">
      <span style="font-weight:800; font-size:1.2rem;">Menu</span>
      <button id="close-btn" style="background:none; border:none; font-size:1.5rem; cursor:pointer;">&times;</button>
    </div>
    <div style="display:flex; flex-direction:column; gap:1.2rem;">
      <a href="/" class="nav-link">Home</a>
      <a href="/about" class="nav-link">About</a>
      <a href="/services" class="nav-link">Services</a>
      <a href="/gallery" class="nav-link">Gallery</a>
      <a href="/testimonials" class="nav-link">Reviews</a>
      <a href="/blog" class="nav-link">Blog</a>
      <a href="/contact" class="nav-link">Contact</a>
      <a href="/contact" class="btn-quote" style="text-align:center; margin-top:1rem;">Get A Quote</a>
    </div>
  </div>

  <main style="flex:1"><slot /></main>

  <footer>
    <div class="footer-top">
      <div class="container footer-flex">
        <div class="footer-left">
          <div class="footer-logo">
            <i class="fas fa-seedling"></i>
            <div>
              {client.name.split(' ')[0]}
              <span>landscape Garden</span>
            </div>
          </div>
          <div class="subscribe-box">
            <h4>Subscribe for Latest Articles and Resources</h4>
            <div class="subscribe-form">
              <input type="email" placeholder="Email Address" />
              <button type="button">Go</button>
            </div>
          </div>
        </div>
        
        <div class="footer-right">
          <div class="footer-links-grid">
            <div class="footer-col">
              <h4>Our Services</h4>
              <ul>
                <li><a href="/services">Lawn Moving</a></li>
                <li><a href="/services">Hedge Cutting</a></li>
                <li><a href="/services">Flower Planting</a></li>
                <li><a href="/about">Working Process</a></li>
                <li><a href="/services">Garden Restoration</a></li>
              </ul>
            </div>
            <div class="footer-col">
              <h4>Links</h4>
              <ul>
                <li><a href="/about">About Us</a></li>
                <li><a href="/about">Our Team</a></li>
                <li><a href="/contact">Contact Us</a></li>
                <li><a href="/about">Our History</a></li>
                <li><a href="/testimonials">Testimonials</a></li>
              </ul>
            </div>
            <div class="footer-col">
              <h4>Contact</h4>
              <p style="margin-bottom:0.5rem">{client.email}</p>
              <p style="margin-bottom:0.5rem">{client.address}<br/>{client.city}, {client.state}</p>
              <p>info@example.com</p>
            </div>
          </div>
          
          <div class="footer-contact-row">
            <div class="footer-socials">
              <a href="#"><i class="fab fa-twitter"></i></a>
              <a href="#"><i class="fab fa-facebook-f"></i></a>
              <a href="#"><i class="fab fa-pinterest-p"></i></a>
              <a href="#"><i class="fab fa-instagram"></i></a>
            </div>
            <div class="footer-call">
              <i class="fas fa-mobile-alt" style="border: 2px solid rgba(255,255,255,0.4); border-radius: 4px; padding: 5px 12px;"></i>
              <div class="footer-call-text">
                <span>Call Anytime</span>
                <strong>{client.phone}</strong>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
    
    <div class="footer-bottom">
      <div class="container" style="position:relative;">
        <div class="footer-bottom-flex">
          <p>Copyright © {new Date().getFullYear()} All Rights Reserved.</p>
          <div class="footer-bottom-links">
            <a href="#">Terms & Condition</a> | <a href="#">Privacy</a> | <a href="#">Support</a>
          </div>
        </div>
        <button class="scroll-top" onclick="window.scrollTo({top: 0, behavior: 'smooth'})">
          <i class="fas fa-chevron-up"></i>
        </button>
      </div>
    </div>
  </footer>

  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />

  <script>
    // Sticky Header Logic
    const header = document.querySelector('header');
    window.addEventListener('scroll', () => {
      if (window.scrollY > 100) {
        header?.classList.add('sticky');
      } else {
        header?.classList.remove('sticky');
      }
    });

    // Mobile Nav Toggle
    const menuBtn = document.getElementById('menu-btn');
    const closeBtn = document.getElementById('close-btn');
    const mobileNav = document.getElementById('mobile-nav');
    const overlay = document.getElementById('overlay');

    menuBtn?.addEventListener('click', () => {
      mobileNav?.classList.add('open');
      overlay?.classList.add('open');
    });

    closeBtn?.addEventListener('click', () => {
      mobileNav?.classList.remove('open');
      overlay?.classList.remove('open');
    });

    overlay?.addEventListener('click', () => {
      mobileNav?.classList.remove('open');
      overlay?.classList.remove('open');
    });

    // Lenis Initialization
    // @ts-ignore
    const lenis = new Lenis({
      duration: 1.2,
      easing: (t: any) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
      orientation: 'vertical',
      gestureOrientation: 'vertical',
      smoothWheel: true,
      wheelMultiplier: 1,
      touchMultiplier: 2,
      infinite: false,
    })

    function raf(time: any) {
      lenis.raf(time)
      requestAnimationFrame(raf)
    }

    requestAnimationFrame(raf)
  </script>
</body>
</html>
